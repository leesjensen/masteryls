{
  "screenId": "ErrorScreen",
  "route": "/error/:code?",
  "viewModel": "ErrorScreenViewModel",
  "viewModelSchema": "../schemas/error.view-model.schema.json",
  "slots": {
    "title": {
      "allowed": [
        "Panel"
      ]
    },
    "message": {
      "allowed": [
        "Panel",
        "InlineError"
      ]
    },
    "recoveryActions": {
      "allowed": [
        "Button"
      ]
    }
  },
  "states": [
    "401",
    "403",
    "404",
    "409",
    "422",
    "500"
  ],
  "allowedComponents": [
    "Panel",
    "InlineError",
    "Button"
  ]
}
