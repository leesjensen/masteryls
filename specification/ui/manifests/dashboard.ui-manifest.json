{
  "screenId": "DashboardScreen",
  "route": "/dashboard",
  "viewModel": "DashboardViewModel",
  "viewModelSchema": "../schemas/dashboard.view-model.schema.json",
  "slots": {
    "header": {
      "allowed": [
        "TopToolbar",
        "Badge"
      ]
    },
    "enrolledSection": {
      "allowed": [
        "CourseCard",
        "EmptyState",
        "Pagination"
      ]
    },
    "discoverSection": {
      "allowed": [
        "CourseCard",
        "InputField",
        "EmptyState",
        "Pagination"
      ]
    },
    "dialogs": {
      "allowed": [
        "ConfirmDialog",
        "AlertBanner"
      ]
    }
  },
  "states": [
    "loading",
    "ready",
    "emptyEnrolled",
    "emptyDiscover",
    "error",
    "readonlyObserver"
  ],
  "allowedComponents": [
    "TopToolbar",
    "Badge",
    "CourseCard",
    "InputField",
    "EmptyState",
    "Pagination",
    "ConfirmDialog",
    "AlertBanner"
  ]
}
