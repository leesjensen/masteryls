{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MasteryLS UI Conformance Coverage Waivers",
  "type": "object",
  "required": ["uiContract", "waivers"],
  "properties": {
    "uiContract": { "type": "string" },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["screenId", "state", "reason"],
        "properties": {
          "screenId": { "type": "string" },
          "state": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
