{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgressScreenViewModel",
  "allOf": [
    { "$ref": "./view-model.common.schema.json" },
    {
      "type": "object",
      "required": ["screenId", "state", "slots"],
      "properties": {
        "screenId": { "const": "ProgressScreen" },
        "state": { "type": "string", "enum": ["loading", "ready", "empty", "error", "readonlyObserver"] },
        "slots": {
          "type": "object",
          "required": ["headerFilters", "timelineTable", "pagination", "dialogs"],
          "properties": {
            "headerFilters": {
              "type": "object",
              "required": ["courseId", "startAt", "endAt"],
              "properties": {
                "courseId": { "type": ["string", "null"] },
                "startAt": { "type": ["string", "null"] },
                "endAt": { "type": ["string", "null"] },
                "eventTypes": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "timelineTable": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["eventId", "eventType", "createdAt"],
                    "properties": {
                      "eventId": { "type": "string" },
                      "eventType": { "type": "string" },
                      "createdAt": { "type": "string" },
                      "courseId": { "type": "string" },
                      "topicId": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "pagination": { "$ref": "./view-model.common.schema.json#/$defs/Pagination" },
            "dialogs": {
              "type": "object",
              "required": ["activeDialog"],
              "properties": {
                "activeDialog": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        { "properties": { "state": { "const": "loading" } } },
        { "properties": { "state": { "const": "ready" } } },
        {
          "properties": {
            "state": { "const": "empty" },
            "slots": {
              "properties": {
                "timelineTable": {
                  "properties": {
                    "items": { "type": "array", "maxItems": 0 }
                  }
                }
              }
            }
          }
        },
        {
          "required": ["errors"],
          "properties": {
            "state": { "const": "error" },
            "errors": { "type": "array", "minItems": 1 }
          }
        },
        {
          "properties": {
            "state": { "const": "readonlyObserver" },
            "readonly": {
              "type": "object",
              "properties": {
                "isReadOnly": { "const": true },
                "isObserverMode": { "const": true }
              },
              "required": ["isReadOnly", "isObserverMode"]
            }
          }
        }
      ]
    }
  ]
}
