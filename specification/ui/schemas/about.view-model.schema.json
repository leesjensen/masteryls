{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AboutScreenViewModel",
  "allOf": [
    { "$ref": "./view-model.common.schema.json" },
    {
      "type": "object",
      "required": ["screenId", "state", "slots"],
      "properties": {
        "screenId": { "const": "AboutScreen" },
        "state": { "type": "string", "enum": ["loading", "ready", "error"] },
        "readonly": {
          "type": "object",
          "properties": {
            "isReadOnly": { "const": true },
            "isObserverMode": { "type": "boolean" }
          },
          "required": ["isReadOnly", "isObserverMode"]
        },
        "slots": {
          "type": "object",
          "required": ["hero", "overview", "capabilities", "integrations", "versionInfo", "supportLinks"],
          "properties": {
            "hero": {
              "type": "object",
              "required": ["title", "subtitle"],
              "properties": {
                "title": { "type": "string" },
                "subtitle": { "type": "string" }
              },
              "additionalProperties": false
            },
            "overview": {
              "type": "object",
              "required": ["body"],
              "properties": {
                "body": { "type": "string" }
              },
              "additionalProperties": false
            },
            "capabilities": {
              "type": "array",
              "items": { "type": "object", "required": ["id", "title"], "properties": { "id": { "type": "string" }, "title": { "type": "string" }, "description": { "type": "string" } }, "additionalProperties": false }
            },
            "integrations": {
              "type": "array",
              "items": { "type": "object", "required": ["name", "status"], "properties": { "name": { "type": "string" }, "status": { "type": "string" } }, "additionalProperties": false }
            },
            "versionInfo": {
              "type": "object",
              "required": ["uiContract", "buildVersion"],
              "properties": {
                "uiContract": { "type": "string" },
                "buildVersion": { "type": "string" },
                "commitSha": { "type": "string" }
              },
              "additionalProperties": false
            },
            "supportLinks": {
              "type": "array",
              "items": { "type": "object", "required": ["label", "href"], "properties": { "label": { "type": "string" }, "href": { "type": "string" } }, "additionalProperties": false }
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        { "properties": { "state": { "const": "loading" } } },
        { "properties": { "state": { "const": "ready" } } },
        { "required": ["errors"], "properties": { "state": { "const": "error" }, "errors": { "type": "array", "minItems": 1 } } }
      ]
    }
  ]
}
