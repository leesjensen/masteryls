{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MasteryLS Common Screen ViewModel",
  "type": "object",
  "required": ["screenId", "route", "state", "readonly", "slots", "actions"],
  "$defs": {
    "RouteContext": {
      "type": "object",
      "required": ["path", "params", "query"],
      "properties": {
        "path": { "type": "string" },
        "params": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "query": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      },
      "additionalProperties": false
    },
    "ReadonlyContext": {
      "type": "object",
      "required": ["isReadOnly", "isObserverMode"],
      "properties": {
        "isReadOnly": { "type": "boolean" },
        "isObserverMode": { "type": "boolean" },
        "reason": {
          "type": "string",
          "enum": ["observer", "permission", "state_lock", "none"]
        },
        "subjectUser": {
          "$ref": "#/$defs/UserSummary"
        }
      },
      "additionalProperties": false
    },
    "UiAction": {
      "type": "object",
      "required": ["id", "label", "enabled", "kind"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "enabled": { "type": "boolean" },
        "kind": {
          "type": "string",
          "enum": ["navigate", "submit", "mutate", "toggle", "retry", "dismiss", "open_dialog"]
        },
        "href": { "type": "string" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "endpoint": { "type": "string" },
        "idempotencyKeyRequired": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ErrorInfo": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "requestId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "BannerInfo": {
      "type": "object",
      "required": ["kind", "message"],
      "properties": {
        "kind": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Pagination": {
      "type": "object",
      "required": ["limit", "hasMore"],
      "properties": {
        "limit": { "type": "integer", "minimum": 1 },
        "nextCursor": { "type": ["string", "null"] },
        "page": { "type": "integer", "minimum": 1 },
        "totalCount": { "type": "integer", "minimum": 0 },
        "hasMore": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "UserSummary": {
      "type": "object",
      "required": ["userId", "displayName"],
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CourseSummary": {
      "type": "object",
      "required": ["courseId", "title"],
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "state": { "type": "string", "enum": ["draft", "published", "archived"] },
        "visibility": { "type": "string", "enum": ["public", "authenticated", "private"] },
        "masteryPercent": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "TopicSummary": {
      "type": "object",
      "required": ["topicId", "title", "type", "status"],
      "properties": {
        "topicId": { "type": "string" },
        "title": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["instruction", "exam", "project", "embedded", "video"]
        },
        "status": { "type": "string", "enum": ["stub", "draft", "published", "archived"] },
        "moduleId": { "type": "string" },
        "position": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "screenId": { "type": "string" },
    "route": { "$ref": "#/$defs/RouteContext" },
    "state": { "type": "string" },
    "readonly": { "$ref": "#/$defs/ReadonlyContext" },
    "slots": { "type": "object" },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/UiAction" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/ErrorInfo" }
    },
    "notices": {
      "type": "array",
      "items": { "$ref": "#/$defs/BannerInfo" }
    }
  },
  "additionalProperties": false
}
