{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CourseCreationViewModel",
  "allOf": [
    { "$ref": "./view-model.common.schema.json" },
    {
      "type": "object",
      "required": ["screenId", "state", "slots"],
      "properties": {
        "screenId": { "const": "CourseCreationScreen" },
        "state": { "type": "string", "enum": ["loading", "ready", "validating", "submitting", "success", "error", "readonlyObserver"] },
        "slots": {
          "type": "object",
          "required": ["form", "progressOverlay", "resultFeedback"],
          "properties": {
            "form": {
              "type": "object",
              "required": ["name", "title", "description", "mode", "owner", "repository"],
              "properties": {
                "name": { "type": "string" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "mode": { "type": "string", "enum": ["template", "ai_generated"] },
                "owner": { "type": "string" },
                "repository": { "type": "string" },
                "credentialStatus": { "type": "string", "enum": ["valid", "invalid", "unknown"] }
              },
              "additionalProperties": false
            },
            "progressOverlay": {
              "type": "object",
              "required": ["active", "step"],
              "properties": {
                "active": { "type": "boolean" },
                "step": { "type": "string" }
              },
              "additionalProperties": false
            },
            "resultFeedback": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string", "enum": ["none", "success", "error"] },
                "message": { "type": "string" },
                "createdCourseId": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        { "properties": { "state": { "const": "loading" } } },
        { "properties": { "state": { "const": "ready" } } },
        { "properties": { "state": { "const": "validating" }, "slots": { "properties": { "progressOverlay": { "properties": { "active": { "const": true } } } } } } },
        { "properties": { "state": { "const": "submitting" }, "slots": { "properties": { "progressOverlay": { "properties": { "active": { "const": true } } } } } } },
        { "properties": { "state": { "const": "success" }, "slots": { "properties": { "resultFeedback": { "properties": { "status": { "const": "success" } } } } } } },
        { "required": ["errors"], "properties": { "state": { "const": "error" }, "errors": { "type": "array", "minItems": 1 } } },
        {
          "properties": {
            "state": { "const": "readonlyObserver" },
            "readonly": {
              "type": "object",
              "properties": {
                "isReadOnly": { "const": true },
                "isObserverMode": { "const": true }
              },
              "required": ["isReadOnly", "isObserverMode"]
            }
          }
        }
      ]
    }
  ]
}
