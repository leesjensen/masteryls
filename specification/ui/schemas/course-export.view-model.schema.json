{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CourseExportViewModel",
  "allOf": [
    { "$ref": "./view-model.common.schema.json" },
    {
      "type": "object",
      "required": ["screenId", "state", "slots"],
      "properties": {
        "screenId": { "const": "CourseExportScreen" },
        "state": { "type": "string", "enum": ["loading", "ready", "running", "partialFailure", "success", "error", "readonlyObserver"] },
        "slots": {
          "type": "object",
          "required": ["targetSelection", "modeControls", "progressLog", "resultSummary"],
          "properties": {
            "targetSelection": {
              "type": "object",
              "required": ["courseId", "canvasCourseId"],
              "properties": {
                "courseId": { "type": "string" },
                "canvasCourseId": { "type": "string" },
                "credentialStatus": { "type": "string", "enum": ["valid", "invalid", "unknown"] }
              },
              "additionalProperties": false
            },
            "modeControls": {
              "type": "object",
              "required": ["mode", "cleanupBeforeExport"],
              "properties": {
                "mode": { "type": "string", "enum": ["full", "incremental", "repair"] },
                "cleanupBeforeExport": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "progressLog": {
              "type": "object",
              "required": ["running", "steps"],
              "properties": {
                "running": { "type": "boolean" },
                "steps": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "resultSummary": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string", "enum": ["none", "success", "partialFailure", "error"] },
                "updatedCount": { "type": "integer", "minimum": 0 },
                "failedCount": { "type": "integer", "minimum": 0 },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "oneOf": [
        { "properties": { "state": { "const": "loading" } } },
        { "properties": { "state": { "const": "ready" } } },
        {
          "properties": {
            "state": { "const": "running" },
            "slots": {
              "properties": {
                "progressLog": { "properties": { "running": { "const": true } } }
              }
            }
          }
        },
        {
          "properties": {
            "state": { "const": "partialFailure" },
            "slots": {
              "properties": {
                "resultSummary": { "properties": { "status": { "const": "partialFailure" } } }
              }
            }
          }
        },
        {
          "properties": {
            "state": { "const": "success" },
            "slots": {
              "properties": {
                "resultSummary": { "properties": { "status": { "const": "success" } } }
              }
            }
          }
        },
        { "required": ["errors"], "properties": { "state": { "const": "error" }, "errors": { "type": "array", "minItems": 1 } } },
        {
          "properties": {
            "state": { "const": "readonlyObserver" },
            "readonly": {
              "type": "object",
              "properties": {
                "isReadOnly": { "const": true },
                "isObserverMode": { "const": true }
              },
              "required": ["isReadOnly", "isObserverMode"]
            }
          }
        }
      ]
    }
  ]
}
