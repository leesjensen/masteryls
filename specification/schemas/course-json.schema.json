{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://masteryls.spec/schemas/course-json.schema.json",
  "title": "CourseJson",
  "type": "object",
  "required": ["course", "modules", "topics"],
  "properties": {
    "course": {
      "type": "object",
      "required": ["id", "name", "title", "description", "state", "visibility", "source"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "state": { "enum": ["draft", "published", "archived"] },
        "visibility": { "enum": ["public", "authenticated", "private"] },
        "deleteProtected": { "type": "boolean" },
        "defaultTopicId": {
          "oneOf": [
            { "$ref": "#/$defs/uuid" },
            { "type": "null" }
          ]
        },
        "source": {
          "type": "object",
          "required": ["provider", "account", "repository", "defaultBranch"],
          "properties": {
            "provider": { "const": "github" },
            "account": { "type": "string", "minLength": 1 },
            "repository": { "type": "string", "minLength": 1 },
            "defaultBranch": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "externalRefs": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "modules": {
      "type": "array",
      "items": { "$ref": "#/$defs/module" }
    },
    "topics": {
      "type": "array",
      "items": { "$ref": "#/$defs/topic" }
    },
    "interactions": {
      "type": "array",
      "items": { "$ref": "#/$defs/interaction" },
      "default": []
    },
    "metadata": {
      "type": "object",
      "properties": {
        "contentVersionMarker": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "$comment": "Cross-reference checks (topic.moduleId exists, course.defaultTopicId exists, and unique position within module) are required in semantic validation stage."
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "module": {
      "type": "object",
      "required": ["id", "title", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "position": { "type": "integer", "minimum": 0 },
        "externalRefs": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "topic": {
      "type": "object",
      "required": ["id", "moduleId", "title", "type", "status", "repoPath", "position"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "moduleId": { "$ref": "#/$defs/uuid" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "default": "" },
        "type": { "enum": ["instruction", "exam", "project", "embedded", "video"] },
        "status": { "enum": ["stub", "draft", "published", "archived"] },
        "repoPath": { "type": "string", "minLength": 1 },
        "position": { "type": "integer", "minimum": 0 },
        "interactionIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/uuid" },
          "default": []
        },
        "externalRefs": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "enum": ["embedded", "video"] }
            }
          },
          "then": {
            "properties": {
              "repoPath": {
                "type": "string",
                "pattern": "^https://"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "interaction": {
      "type": "object",
      "required": ["id", "topicId", "type", "gradingPolicy"],
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "topicId": { "$ref": "#/$defs/uuid" },
        "type": {
          "enum": [
            "multiple_choice",
            "multiple_select",
            "survey",
            "essay",
            "file_submission",
            "url_submission",
            "teaching",
            "prompt"
          ]
        },
        "title": { "type": "string", "default": "" },
        "prompt": { "type": "string", "default": "" },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "gradingPolicy": { "enum": ["auto", "manual", "mixed", "none"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
